# Database (Supabase PostgreSQL — direct connection, port 5432, NOT pooler port 6432)
# Used for both local development and production.
DATABASE_URL=postgresql+asyncpg://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
DATABASE_URL_SYNC=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
DATABASE_SSL=true

# Supabase
SUPABASE_URL=https://[PROJECT-REF].supabase.co
SUPABASE_ANON_KEY=REPLACE_ME

# Redis
REDIS_URL=redis://localhost:6379/0

# Stripe
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
STRIPE_API_VERSION=2024-12-18

# JWT
JWT_SECRET_KEY=REPLACE_WITH_RANDOM_SECRET
JWT_ALGORITHM=HS256

# CORS
ALLOWED_ORIGINS=http://localhost:4200,http://localhost:3000

# Security
API_KEY_SALT=REPLACE_WITH_RANDOM_SALT

# App
ENVIRONMENT=development
LOG_LEVEL=INFO
